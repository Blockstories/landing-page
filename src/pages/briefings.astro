<script>
// ═══ Content Tabs ═══
const contentTabs=document.getElementById('contentTabs');
if(contentTabs){
  const feat=document.querySelector('.feat');
  const allItems=document.querySelectorAll('[data-type]');
  const sections=document.querySelectorAll('[data-section]');
  const pullQuote=null;
  const inlineCta=document.querySelector('.inline-cta');
  const authorsSec=document.querySelector('.authors-sec');

  contentTabs.querySelectorAll('.tab').forEach(t=>{
    t.addEventListener('click',()=>{
      contentTabs.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
      t.classList.add('on');
      const f=t.dataset.f;

      // Featured card
      if(f==='all') feat.style.display='';
      else feat.style.display=feat.dataset.type===f?'':'none';

      // Individual items within sections
      allItems.forEach(item=>{
        if(f==='all') item.style.display='';
        else item.style.display=item.dataset.type===f?'':'none';
      });

      // Sections — show/hide by matching type
      sections.forEach(s=>{
        if(f==='all') s.style.display='';
        else s.style.display=s.dataset.section===f?'':'none';
      });

      // Decorative elements — only show in "all" view
      [pullQuote,inlineCta,authorsSec].forEach(el=>{
        if(el) el.style.display=f==='all'?'':'none';
      });
    });
  });
}

// ═══ Scroll Reveal ═══
const observer=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
</script>

