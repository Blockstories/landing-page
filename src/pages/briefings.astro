---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Briefings — Blockstories">
<style>
/* ═══ PAGE HERO ═══ */
.page-hero{
  border-bottom:1px solid var(--border);padding:3.5rem 0 3rem;
  background:linear-gradient(170deg,#F0F4FA 0%,#F7F8FB 40%,var(--bg) 100%);
}
.page-eyebrow{font-size:.6rem;text-transform:uppercase;letter-spacing:.2em;color:var(--accent);font-weight:600;font-family:var(--sans);margin-bottom:1rem}
.page-headline{font-family:var(--display);font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;line-height:1.12;letter-spacing:-.025em;margin-bottom:.8rem}
.page-subtitle{font-family:var(--body);font-size:1rem;color:var(--text-2);line-height:1.7;max-width:560px}

/* ═══ SEARCH BAR ═══ */
.search-bar{margin-top:2rem;max-width:620px}
.search-bar-inner{display:flex;align-items:center;background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;transition:border-color var(--ease)}
.search-bar-inner:focus-within{border-color:var(--accent)}
.search-icon{flex-shrink:0;margin-left:16px;color:var(--text-3)}
.search-input{flex:1;border:none;background:transparent;padding:14px 14px;font-family:var(--sans);font-size:.9rem;color:var(--text-1);outline:none}
.search-input::placeholder{color:var(--ink-faint)}
.search-btn{flex-shrink:0;margin:5px;padding:10px 24px;border:none;border-radius:6px;background:var(--surface-dark);color:#fff;font-family:var(--sans);font-size:.8rem;font-weight:600;letter-spacing:.03em;cursor:pointer;transition:background var(--ease)}
.search-btn:hover{background:#0d2033}

/* ═══ LOAD MORE ═══ */
.load-more-wrap{text-align:center;margin-top:var(--sp-l)}
.load-more-btn{display:inline-block;padding:12px 36px;border:1px solid var(--border);border-radius:6px;background:var(--bg);font-family:var(--sans);font-size:.85rem;font-weight:500;color:var(--text-2);cursor:pointer;transition:all var(--ease)}
.load-more-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-light)}

/* ═══ STICKY TABS ═══ */
.sticky-tabs{position:sticky;top:56px;z-index:90;background:rgba(255,255,255,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:14px 0}
.tabs{display:flex;gap:2px;flex-wrap:wrap}
.tab{font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:6px 16px;border-radius:2px;cursor:pointer;color:var(--text-3);background:none;border:1px solid transparent;transition:all var(--ease)}
.tab:hover{color:var(--text-2);border-color:var(--border)}
.tab.on{background:var(--text-1);color:var(--bg);border-color:var(--text-1)}

/* ═══ SECTION DIVIDER ═══ */
.sdiv{display:flex;justify-content:space-between;align-items:baseline;padding-bottom:10px;border-bottom:2px solid var(--text-1);margin-bottom:22px}
.sdiv h2{font-family:var(--serif);font-size:1.3rem;font-weight:400;letter-spacing:-.01em}
.sdiv a{font-family:var(--mono);font-size:.6rem;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3);transition:color var(--ease)}
.sdiv a:hover{color:var(--text-1)}

/* ═══ FEATURED BRIEFING ═══ */
.feat{display:grid;grid-template-columns:1fr 1fr;gap:0;margin-bottom:48px;border:1px solid var(--border);border-radius:6px;overflow:hidden;background:var(--surface);cursor:pointer;transition:box-shadow var(--ease)}
.feat:hover{box-shadow:0 8px 36px rgba(0,0,0,.06)}
.feat-vis{position:relative;min-height:340px;background:var(--surface-dark);overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;padding:32px}
.feat-vis::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(90,138,134,.15),rgba(18,43,66,.9));z-index:1}
.feat-experts-vis{position:relative;z-index:2;margin-bottom:16px}
.feat-experts-vis-label{font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:12px}
.feat-experts-vis-row{display:flex;gap:16px}
.feat-expert-vis{text-align:center}
.feat-expert-vis-avatar{width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.2);overflow:hidden;margin:0 auto 5px}
.feat-expert-vis-avatar img{width:100%;height:100%;object-fit:cover}
.feat-expert-vis-name{font-size:.7rem;font-weight:500;color:#fff;white-space:nowrap}
.feat-expert-vis-co{font-family:var(--mono);font-size:.45rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.5)}

.feat-txt{padding:40px;display:flex;flex-direction:column;justify-content:center}
.feat-type{font-family:var(--mono);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:12px}
.feat-txt h3{font-family:var(--display);font-size:1.65rem;font-weight:600;line-height:1.22;letter-spacing:-.02em;margin-bottom:14px}
.feat-txt .excerpt{font-family:var(--body);font-size:.9rem;line-height:1.65;color:var(--text-2);margin-bottom:18px}
.feat-meta{font-family:var(--mono);font-size:.65rem;color:var(--text-3)}
.feat-also{margin-top:20px;padding-top:18px;border-top:1px solid var(--border)}
.feat-also-label{font-family:var(--mono);font-size:.55rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:12px}
.feat-also-list{list-style:disc;padding-left:18px;display:flex;flex-direction:column;gap:10px}
.feat-also-list li{font-size:.82rem;line-height:1.55;color:var(--text-2)}
.feat-also-list li strong{color:var(--text-1);font-weight:600}

/* ═══ CONTENT GRID ═══ */
.content-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px}

/* ═══ BRIEFING CARD ═══ */
.bc{background:var(--surface);border:1px solid var(--border);border-radius:5px;overflow:hidden;cursor:pointer;transition:all var(--ease)}
.bc:hover{border-color:var(--text-3);transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.06)}
.bc-header{background:var(--surface-dark);padding:20px;position:relative;min-height:240px;display:flex;flex-direction:column;justify-content:flex-end}
.bc-header::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(90,138,134,.12),rgba(18,43,66,.85))}
.bc-header *{position:relative;z-index:1}
.bc-header .bc-type{font-family:var(--mono);font-size:.45rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:6px}
.bc-header h4{font-family:var(--serif);font-size:1.05rem;color:#fff;font-weight:400;line-height:1.3}
.bc-header.bc-crypto{background:linear-gradient(135deg,#1a4a3a,#0f3a2a)}
.bc-header.bc-crypto::before{background:linear-gradient(135deg,rgba(18,183,106,.15),rgba(15,58,42,.85))}
.bc-body{padding:18px 20px}
.bc-body p{font-size:.78rem;line-height:1.55;color:var(--text-2);margin-bottom:12px}
.bc-meta{font-family:var(--mono);font-size:.6rem;color:var(--text-3)}
.bc-authors{display:flex;gap:8px;margin-top:12px;align-items:center}
.bc-author-dot{width:24px;height:24px;border-radius:50%;background:var(--surface-warm);border:1px solid var(--border);overflow:hidden}
.bc-author-dot img{width:100%;height:100%;object-fit:cover}

/* ═══ REPORT CARD ═══ */
.rc{background:var(--surface);border:1px solid var(--border);border-radius:5px;overflow:hidden;cursor:pointer;transition:all var(--ease)}
.rc:hover{border-color:var(--text-3);transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.06)}
.rc-vis{height:180px;background:var(--surface-dark);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.rc-vis::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(90,138,134,.08),rgba(18,43,66,.7))}
.rc-vis .rc-badge{position:absolute;top:12px;left:12px;z-index:1;font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;text-transform:uppercase;padding:3px 9px;border-radius:2px;background:rgba(255,255,255,.15);backdrop-filter:blur(8px);color:rgba(255,255,255,.8)}
.rc-vis .rc-icon{position:relative;z-index:1;font-size:2.5rem;color:rgba(255,255,255,.2)}
.rc-body{padding:18px 20px}
.rc-body .rc-type{font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:6px}
.rc-body h4{font-family:var(--serif);font-size:1.05rem;font-weight:400;line-height:1.3;margin-bottom:6px}
.rc-body p{font-size:.78rem;line-height:1.55;color:var(--text-2);margin-bottom:12px}
.rc-stats{display:flex;gap:16px;margin-bottom:12px}
.rc-stat{font-family:var(--mono);font-size:.55rem;color:var(--text-3);letter-spacing:.04em;text-transform:uppercase}
.rc-stat strong{color:var(--text-1);font-weight:600;font-size:.7rem}
.rc-dl{font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:8px 16px;background:var(--accent);color:#fff;border:none;border-radius:3px;cursor:pointer;transition:background var(--ease);display:inline-block}
.rc-dl:hover{background:var(--accent-hover)}

/* ═══ INTERVIEW CARD ═══ */
.ic{background:var(--surface);border:1px solid var(--border);border-radius:5px;overflow:hidden;cursor:pointer;transition:all var(--ease)}
.ic:hover{border-color:var(--text-3);transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.06)}
.ic-vis{height:160px;background:var(--surface-warm);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.ic-vis .ic-badge{position:absolute;top:12px;left:12px;z-index:1;font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;text-transform:uppercase;padding:3px 9px;border-radius:2px;background:var(--accent);color:#fff}
.ic-vis .ic-avatar{width:80px;height:80px;border-radius:50%;background:var(--border);border:3px solid var(--bg)}
.ic-body{padding:18px 20px}
.ic-body .ic-type{font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:6px}
.ic-body h4{font-family:var(--serif);font-size:1rem;font-weight:400;line-height:1.3;margin-bottom:4px}
.ic-body .ic-role{font-size:.75rem;color:var(--text-3);margin-bottom:8px}
.ic-body p{font-size:.78rem;line-height:1.55;color:var(--text-2)}
.ic-meta{font-family:var(--mono);font-size:.6rem;color:var(--text-3);margin-top:10px}

/* ═══ EXPERT TAKES — OP-ED STRIPS ═══ */
.etc-list{display:flex;flex-direction:column;gap:0}
.etc{display:grid;grid-template-columns:48px 1fr auto;gap:20px;align-items:start;padding:24px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:background var(--ease)}
.etc:first-child{border-top:1px solid var(--border)}
.etc:hover{background:var(--accent-light);margin:0 -20px;padding:24px 20px;border-radius:4px}
.etc-author-dot{width:48px;height:48px;border-radius:50%;background:var(--surface-warm);border:2px solid var(--border);overflow:hidden;flex-shrink:0}
.etc-author-dot img{width:100%;height:100%;object-fit:cover}
.etc-body{display:flex;flex-direction:column;gap:6px}
.etc-quote{font-family:var(--serif);font-size:1.05rem;font-weight:400;line-height:1.4;color:var(--text-1)}
.etc-quote::before{content:'\201C';color:var(--accent);font-size:1.4rem;font-weight:700;margin-right:2px}
.etc-desc{font-size:.78rem;line-height:1.5;color:var(--text-2)}
.etc-byline{display:flex;align-items:baseline;gap:6px;flex-wrap:wrap}
.etc-author-name{font-weight:600;font-size:.78rem;color:var(--text-1)}
.etc-role{font-size:.7rem;color:var(--text-3)}
.etc-meta{font-family:var(--mono);font-size:.55rem;color:var(--ink-faint)}
.etc-read{font-family:var(--mono);font-size:.6rem;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);white-space:nowrap;padding-top:4px;opacity:0;transition:opacity var(--ease)}
.etc:hover .etc-read{opacity:1}

/* ═══ AUTHORS SECTION ═══ */
.authors-sec{padding:var(--sp-xl) 0;border-top:1px solid var(--border)}
.authors-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:24px}
.author-card{text-align:center;padding:28px 20px;background:var(--surface);border:1px solid var(--border);border-radius:5px}
.author-photo{width:72px;height:72px;border-radius:50%;background:var(--surface-warm);border:2px solid var(--border);margin:0 auto 14px;overflow:hidden}
.author-photo img{width:100%;height:100%;object-fit:cover}
.author-card h4{font-family:var(--serif);font-size:1.05rem;font-weight:400;margin-bottom:2px}
.author-card .author-role{font-family:var(--mono);font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:10px}
.author-card p{font-size:.78rem;line-height:1.55;color:var(--text-2)}
.author-socials{display:flex;justify-content:center;gap:12px;margin-top:12px}
.author-socials a{display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;border:1px solid var(--border);color:var(--text-3);transition:all var(--ease)}
.author-socials a:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-light)}
.author-socials svg{width:14px;height:14px}

/* ═══ PULL QUOTE ═══ */
.pull-quote{padding:28px 32px;margin:0 0 48px;border-top:none;border-bottom:none;border-left:3px solid var(--accent);background:var(--accent-light);border-radius:0 6px 6px 0}
.pull-quote blockquote{font-family:var(--display);font-size:1.15rem;font-style:italic;font-weight:400;line-height:1.55;color:var(--text-1);max-width:680px}
.pull-quote cite{display:block;margin-top:12px;font-family:var(--mono);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);font-style:normal}

/* ═══ CTA BREAK ═══ */
.cta-break{background:var(--surface-dark);padding:52px 48px;border-radius:6px;margin:48px 0;display:flex;align-items:center;gap:48px}
.cta-txt{flex:1}
.cta-txt h3{font-family:var(--display);font-size:1.5rem;font-weight:700;color:#fff;line-height:1.25;margin-bottom:8px}
.cta-txt h3 em{font-style:italic;font-weight:400;color:var(--accent)}
.cta-txt p{font-size:.84rem;color:rgba(255,255,255,.55);line-height:1.6;max-width:440px}
.cta-form{flex-shrink:0}
.cta-form .row{display:flex;gap:6px}
.cta-form input{font-family:var(--sans);font-size:.78rem;padding:11px 14px;width:240px;border:1px solid rgba(255,255,255,.15);border-radius:3px;background:rgba(255,255,255,.06);color:#fff;outline:none;transition:border-color var(--ease)}
.cta-form input:focus{border-color:rgba(255,255,255,.35)}
.cta-form input::placeholder{color:rgba(255,255,255,.3)}
.cta-form button{font-family:var(--sans);font-size:.78rem;font-weight:500;padding:11px 22px;background:var(--accent);color:#fff;border:none;border-radius:3px;cursor:pointer;transition:opacity var(--ease)}
.cta-form button:hover{opacity:.85}

/* ═══ PAGINATION ═══ */
.pagination{display:flex;justify-content:center;gap:4px;padding:36px 0}
.pg{font-family:var(--mono);font-size:.65rem;width:34px;height:34px;display:flex;align-items:center;justify-content:center;border:1px solid var(--border);border-radius:3px;cursor:pointer;transition:all var(--ease);color:var(--text-2)}
.pg:hover{border-color:var(--text-3)}
.pg.on{background:var(--text-1);color:var(--bg);border-color:var(--text-1)}

/* ═══ HERO STAT BAR ═══ */
.hero-stat-bar{display:flex;gap:24px;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)}
.hero-stat-item{font-family:var(--mono);font-size:.6rem;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3)}
.hero-stat-item strong{color:var(--text-1);font-weight:600;font-size:.75rem;margin-right:4px}

/* ═══ EDITORIAL SECTIONS ═══ */
.ed-section{margin-bottom:48px}
.section-grid--3{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.section-intro{font-family:var(--body);font-size:.88rem;color:var(--text-2);line-height:1.6;max-width:560px;margin-bottom:20px;margin-top:-10px}

/* ═══ INLINE CTA ═══ */
.inline-cta{display:flex;align-items:center;justify-content:space-between;gap:32px;padding:24px 28px;background:var(--accent-light);border:1px solid rgba(90,138,134,.18);border-left:3px solid var(--accent);border-radius:0 4px 4px 0;margin-bottom:48px}
.inline-cta-label{font-family:var(--mono);font-size:.55rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:4px}
.inline-cta-txt p{font-size:.82rem;color:var(--text-2);line-height:1.5}
.inline-cta-form{display:flex;gap:6px;flex-shrink:0}
.inline-cta-form input{font-family:var(--sans);font-size:.78rem;padding:9px 14px;width:220px;border:1px solid var(--border);border-radius:3px;background:var(--bg);outline:none;transition:border-color var(--ease)}
.inline-cta-form input:focus{border-color:var(--accent)}
.inline-cta-form input::placeholder{color:var(--ink-faint);font-family:var(--mono);font-size:.65rem}
.inline-cta-form button{font-family:var(--sans);font-size:.78rem;font-weight:500;padding:9px 20px;background:var(--accent);color:#fff;border:none;border-radius:3px;cursor:pointer;transition:background var(--ease)}
.inline-cta-form button:hover{background:var(--accent-hover)}

/* ═══ REPORT SHOWCASE ═══ */
.report-showcase{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.report-featured .rc{height:100%;display:flex;flex-direction:column}
.report-featured .rc-vis{height:220px;flex-shrink:0}
.report-featured .rc-body{flex:1}
.report-secondary{display:flex;flex-direction:column;gap:20px}
.report-secondary .rc{display:flex;flex-direction:row;overflow:hidden}
.report-secondary .rc-vis{height:auto;width:180px;min-height:140px;flex-shrink:0}
.report-secondary .rc-body{flex:1}


.reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

@media(max-width:1024px){
  .feat{grid-template-columns:1fr}
  .feat-vis{min-height:200px}
  .section-grid--3{grid-template-columns:repeat(2,1fr)}
  .authors-grid{grid-template-columns:repeat(2,1fr)}
  .etc{grid-template-columns:48px 1fr}
  .etc-read{display:none}
  .report-showcase{grid-template-columns:1fr}
  .report-secondary .rc{flex-direction:column}
  .report-secondary .rc-vis{width:100%;min-height:140px}
  .inline-cta{flex-direction:column;gap:16px}
  .clocks{display:none}
  .cta-break{flex-direction:column;padding:32px 28px}
  .hero-stat-bar{flex-wrap:wrap;gap:16px}
}
@media(max-width:640px){
  .wrap{padding:0 20px}
  .nav{display:none}
  .section-grid--3{grid-template-columns:1fr}
  .authors-grid{grid-template-columns:1fr}
  .etc{grid-template-columns:40px 1fr}
  .etc-author-dot{width:40px;height:40px}
  .report-showcase{grid-template-columns:1fr}
  .tabs{overflow-x:auto;flex-wrap:nowrap;-webkit-overflow-scrolling:touch}
  .feat-txt{padding:24px}
  .cta-form .row{flex-direction:column}
  .cta-form input{width:100%}
  .hero-stat-bar{flex-direction:column;gap:8px}
  .inline-cta-form{flex-direction:column}
  .inline-cta-form input{width:100%}
}
</style>

<!-- ═══ MASTHEAD ═══ -->
<header class="masthead">
  <div class="wrap">
    <div class="masthead-top">
