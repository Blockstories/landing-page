<script>
// ═══ Content Tabs ═══
const contentTabs=document.getElementById('contentTabs');
if(contentTabs){
  const feat=document.querySelector('.feat') as HTMLElement | null;
  const allItems=document.querySelectorAll('[data-type]');
  const sections=document.querySelectorAll('[data-section]');
  const pullQuote=null;
  const inlineCta=document.querySelector('.inline-cta') as HTMLElement | null;
  const authorsSec=document.querySelector('.authors-sec') as HTMLElement | null;

  contentTabs.querySelectorAll('.tab').forEach(tab=>{
    const t = tab as HTMLElement;
    t.addEventListener('click',()=>{
      contentTabs.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
      t.classList.add('on');
      const f=t.dataset.f;

      // Featured card
      if(feat){
        if(f==='all') feat.style.display='';
        else feat.style.display=feat.dataset.type===f?'':'none';
      }

      // Individual items within sections
      allItems.forEach(item=>{
        const el = item as HTMLElement;
        if(f==='all') el.style.display='';
        else el.style.display=el.dataset.type===f?'':'none';
      });

      // Sections — show/hide by matching type
      sections.forEach(s=>{
        const el = s as HTMLElement;
        if(f==='all') el.style.display='';
        else el.style.display=el.dataset.section===f?'':'none';
      });

      // Decorative elements — only show in "all" view
      [pullQuote,inlineCta,authorsSec].forEach(el=>{
        if(el) (el as HTMLElement).style.display=f==='all'?'':'none';
      });
    });
  });
}

// ═══ Scroll Reveal ═══
const observer=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
</script>

<script>
