<div class="wrap">
  <div class="dateline">
    <span class="dateline-date" id="dateline">Tuesday, March 4, 2026</span>
    <div class="dateline-live"><span class="dateline-live-dot"></span> Live Updates</div>
  </div>

  <!-- ═══ FEATURED NEWS ═══ -->
  <div class="featured">
    <div class="featured-top">
      <div class="featured-label">Featured News</div>
      <div class="featured-arrow">Scroll <span>→</span></div>
    </div>
    <div class="featured-scroll-wrap">
    <div class="featured-scroll">
      {featuredNews.length > 0 ? (
        featuredNews.slice(0, 10).map((item) => {
          const imageUrl = getNewsImage(item);
          const title = String(item.fields?.title || '');
          const bpoints = String(item.fields?.bpoints || '');
          // Softr created date can be in various field names
          const createdAt = String(item.fields?.['Created At'] || item.fields?.created_at || item.fields?.firstPublished || item.fields?.createdAt || item.created_at || '');
          const theme = String(item.fields?.theme || 'news');
          // Softr field names: 'links' for URLs, 'publisher' for sources
          const links = item.fields?.links;
          const urls = Array.isArray(links) ? links.filter((u): u is string => typeof u === 'string' && u.length > 0)
                     : typeof links === 'string' && links ? [links] : [];
          const publisherField = item.fields?.publisher;
          const sources = Array.isArray(publisherField) ? publisherField.filter((s): s is string => typeof s === 'string' && s.length > 0)
                         : typeof publisherField === 'string' && publisherField ? [publisherField] : [];
          const displaySource = sources[0] || 'News';

          return (
            <div
              class="fc news-item"
              data-sources={JSON.stringify(sources.length ? sources : [displaySource])}
              data-urls={JSON.stringify(urls)}
            >
              {imageUrl ? (
                <div class="fc-visual" style={`background-image:url(${imageUrl});background-size:cover;background-position:center;`}>
                </div>
              ) : (
                <div class="fc-visual" style="background:linear-gradient(135deg,#1a1a2e 0%,#4a3f6b 100%)">
                  <span class="fc-visual-name">{displaySource}</span>
                </div>
              )}
              <div class="fc-body">
                <div class="fc-source">{displaySource}</div>
                <div class="fc-title">{title}</div>
                <div class="fc-meta">
                  <div class="fc-time">{formatNewsTime(createdAt)}</div>
                  <span class="fc-tag">{theme}</span>
                </div>
              </div>
            </div>
          );
        })
      ) : (
        <div class="fc">
          <div class="fc-visual" style="background:linear-gradient(135deg,#1a1a2e 0%,#4a3f6b 100%)">
            <span class="fc-visual-name">No Featured News</span>
          </div>
          <div class="fc-body">
            <div class="fc-title">Check back later for featured updates</div>
          </div>
        </div>
      )}
    </div>
    </div>
  </div>

  <div class="newsfeed-heading">Live Newsfeed <span class="live-dot"></span></div>

  <div class="filter-bar">
