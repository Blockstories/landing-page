---
import Layout from '../layouts/Layout.astro';
import { getLatestNews, type MappedRecord } from '../../../backend/services/softrService.js';

const pageStart = performance.now();
console.log(`[news.astro] Starting render`);

// Softr news records
let newsItems: MappedRecord[] = [];
let featuredNews: MappedRecord[] = [];

// Only fetch data during SSR (not during static build)
const isBuildTime = import.meta.env.MODE === "production" && !import.meta.env.SSR;

if (!isBuildTime) {
  try {
    console.log(`[news.astro] Fetching Softr news...`);
    const fetchStart = performance.now();
    const result = await getLatestNews({ paging: { limit: 50 } });
    console.log(`[news.astro] Data fetched in ${(performance.now() - fetchStart).toFixed(2)}ms`);
    newsItems = result.data;

    // Filter featured news: visibility field is not empty
    featuredNews = newsItems.filter(item => {
      const visibility = item.fields?.visibility;
      return visibility !== undefined && visibility !== null && visibility !== '';
    });

    console.log(`[news.astro] Total news: ${newsItems.length}, Featured: ${featuredNews.length}`);
  } catch (error) {
    console.error("[news.astro] Failed to fetch news:", error);
  }
}

const totalTime = performance.now() - pageStart;
console.log(`[news.astro] Total SSR time: ${totalTime.toFixed(2)}ms`);

// Helper function to format time from date string
// Shows relative time if < 12 hours ago, otherwise shows date + time
function formatNewsTime(dateString: string): string {
  if (!dateString) return '';
  const date = new Date(dateString);
  if (isNaN(date.getTime())) return '';

  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffMinutes = Math.floor(diffMs / (1000 * 60));
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));

  // Less than 12 hours ago: show relative time
  if (diffHours < 12) {
    if (diffMinutes < 1) return 'just now';
    if (diffMinutes < 60) return `${diffMinutes} minute${diffMinutes === 1 ? '' : 's'} ago`;
    return `${diffHours} hour${diffHours === 1 ? '' : 's'} ago`;
  }

  // Otherwise: show date + time
  const isToday = date.toDateString() === now.toDateString();
  const isYesterday = new Date(now.getTime() - 24 * 60 * 60 * 1000).toDateString() === date.toDateString();
  const timeStr = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

  if (isToday) return `Today, ${timeStr}`;
  if (isYesterday) return `Yesterday, ${timeStr}`;

  const formattedDate = date.toLocaleDateString([], { month: 'short', day: 'numeric' });
  return `${formattedDate}, ${timeStr}`;
}

function getSourceFromUrl(url: string): string {
  if (!url) return 'Unknown';
  try {
    const hostname = new URL(url).hostname.replace('www.', '');
    const parts = hostname.split('.');
    return parts[parts.length - 2]?.charAt(0).toUpperCase() + parts[parts.length - 2]?.slice(1) || hostname;
  } catch {
    return 'Unknown';
  }
}

function getNewsImage(item: MappedRecord): string | null {
  const imageFile = item.fields?.imageFile;
  if (Array.isArray(imageFile) && imageFile.length > 0) {
    return imageFile[0]?.url || null;
  }
  if (typeof imageFile === 'object' && imageFile?.url) {
    return imageFile.url;
  }
  return null;
}

function formatSources(sources: string[]): string {
  if (sources.length === 0) return 'Unknown';
  if (sources.length === 1) return sources[0];
  if (sources.length > 10) return `${sources[0]} +${sources.length - 1} more`;
  // Show all sources separated by commas
  return sources.join(', ');
}
---

<Layout title="News — Blockstories">
<style>
/* ═══ BREAKING BANNER ═══ */
.breaking{background:var(--surface-dark);padding:12px 0;overflow:hidden}
.breaking-inner{display:flex;align-items:center;gap:16px}
.breaking-badge{display:flex;align-items:center;gap:6px;flex-shrink:0;font-family:var(--mono);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:#fff;font-weight:500}
.breaking-dot{width:6px;height:6px;border-radius:50%;background:var(--red);animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.breaking-text{font-family:var(--body);font-size:.85rem;color:rgba(255,255,255,.85);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.breaking-text strong{color:#fff;font-weight:600}
.breaking-time{flex-shrink:0;font-family:var(--mono);font-size:.55rem;color:rgba(255,255,255,.4);letter-spacing:.06em}

/* ═══ DATELINE ═══ */
.dateline{border-bottom:1px solid var(--border);padding:14px 0;display:flex;align-items:center;justify-content:space-between}
.dateline-date{font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3)}
.dateline-live{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;color:var(--green);font-weight:500}
.dateline-live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 1.5s ease-in-out infinite}

/* ═══ SEARCH + FILTERS ═══ */
.filter-bar{padding:20px 0;display:flex;align-items:center;gap:16px;border-bottom:1px solid var(--border)}
.search-wrap{position:relative;flex:1;max-width:320px}
.search-wrap input{width:100%;font-family:var(--sans);font-size:.78rem;padding:9px 14px 9px 34px;border:1px solid var(--border);border-radius:3px;background:var(--surface);outline:none;transition:border-color var(--ease)}
.search-wrap input:focus{border-color:var(--text-3)}
.no-results-message {
  padding: 40px 20px;
  text-align: center;
  color: var(--text-3);
  font-family: var(--sans);
  font-size: 0.9rem;
}
.no-results-message.hidden {
  display: none;
}
.search-wrap input::placeholder{color:var(--ink-faint);font-family:var(--mono);font-size:.7rem}
.search-icon{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--text-3);font-size:.75rem}
.tabs{display:flex;gap:2px;flex-wrap:wrap}
.tab{font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:6px 14px;border-radius:2px;cursor:pointer;color:var(--text-3);background:none;border:1px solid transparent;transition:all var(--ease)}
.tab:hover{color:var(--text-2);border-color:var(--border)}
.tab.on{background:var(--text-1);color:var(--bg);border-color:var(--text-1)}

/* ═══ NEWSFEED HEADING ═══ */
.newsfeed-heading{
  font-family:var(--mono);font-size:1.1rem;letter-spacing:.10em;text-transform:uppercase;
  color:var(--text-1);display:flex;align-items:center;gap:12px;font-weight:500;
  padding:32px 0 6px;
}
.live-dot{
  width:9px;height:9px;border-radius:50%;background:var(--accent);flex-shrink:0;
  animation:live-pulse 2s ease-in-out infinite;
}
@keyframes live-pulse{0%,100%{box-shadow:0 0 0 0 rgba(90,138,134,.4)}50%{box-shadow:0 0 0 6px rgba(90,138,134,0)}}

/* ═══ MAIN GRID ═══ */
.news-grid{display:grid;grid-template-columns:1fr 320px;gap:0;min-height:80vh}

/* ═══ FEED ═══ */
.feed{border-right:1px solid var(--border);padding:0 12px;min-width:0;max-height:1400px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.feed::-webkit-scrollbar{width:6px}
.feed::-webkit-scrollbar-track{background:transparent}
.feed::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.feed-group{margin-bottom:0}
.feed-group-label{font-family:var(--mono);font-size:.5rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);padding:20px 0 12px;margin-bottom:0;display:flex;align-items:center;gap:10px;position:sticky;top:0;background:var(--bg);z-index:1}

/* ═══ NEWS ITEM ═══ */
.ni{display:grid;grid-template-columns:1fr;gap:0;padding:18px 0;border-bottom:1px solid var(--border-light);cursor:pointer;transition:background var(--ease)}
.ni:hover{background:var(--surface);padding:18px 12px;margin:0 -12px;border-radius:4px}
.ni-meta{display:flex;align-items:center;gap:10px;margin-bottom:6px}
.ni-time{font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.04em}
.ni-src{font-family:var(--mono);font-size:.5rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-faint)}
.ni-body h3{font-family:var(--body);font-size:.95rem;font-weight:500;line-height:1.45;margin-bottom:6px;letter-spacing:-.01em}
.ni-body p{font-size:.8rem;line-height:1.55;color:var(--text-2)}
.ni-tags{display:flex;gap:4px;margin-top:10px;flex-wrap:wrap}
.ni-tag{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;border-radius:2px;background:var(--surface);border:1px solid var(--border);color:var(--text-3)}

/* News Item Clickable */
.ni.news-item,
.fc.news-item {
  cursor: pointer;
}
.ni.news-item:hover,
.fc.news-item:hover {
  border-color: var(--text-3);
}

/* News Popup Publisher List */
.news-popup__list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px}
.news-popup__list li{margin:0}
.news-popup__list a{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;background:var(--surface);border:1.5px solid var(--border);border-radius:10px;text-decoration:none;color:var(--text-1);transition:all 0.2s cubic-bezier(0.16,1,0.3,1);position:relative;overflow:hidden}
.news-popup__list a::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent);transform:scaleY(0);transition:transform 0.2s ease}
.news-popup__list a:hover{border-color:var(--accent);transform:translateX(4px);box-shadow:0 4px 20px rgba(0,0,0,.08)}
.news-popup__list a:hover::before{transform:scaleY(1)}
.news-popup__publisher{font-size:0.95rem;font-weight:500;display:flex;align-items:center;gap:10px}
.news-popup__publisher::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--accent);opacity:0.6}
.news-popup__arrow{font-size:1.1rem;opacity:0.4;transition:all 0.2s ease;transform:translateX(-4px)}
.news-popup__list a:hover .news-popup__arrow{opacity:1;transform:translateX(0);color:var(--accent)}

/* ═══ FEATURED NEWS ═══ */
.featured{padding:28px 0 6px;border-bottom:1px solid var(--border)}
.featured-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.featured-label{font-family:var(--mono);font-size:1.1rem;letter-spacing:.10em;text-transform:uppercase;color:var(--text-1);display:flex;align-items:center;font-weight:500}
.featured-arrow{display:flex;align-items:center;gap:4px;font-family:var(--mono);font-size:.5rem;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-faint);cursor:pointer;transition:color var(--ease)}
.featured-arrow:hover{color:var(--text-2)}
.featured-arrow span{font-size:.75rem;transition:transform var(--ease)}
.featured-arrow:hover span{transform:translateX(3px)}
.featured-scroll-wrap{position:relative}
.featured-scroll-wrap::after{content:'';position:absolute;top:0;right:0;bottom:0;width:48px;background:linear-gradient(to left,var(--bg),transparent);pointer-events:none;z-index:1}
.featured-scroll{display:flex;gap:14px;overflow-x:auto;padding-bottom:22px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.featured-scroll::-webkit-scrollbar{display:none}
.fc{flex:0 0 248px;border:1px solid var(--border);border-radius:4px;overflow:hidden;cursor:pointer;transition:all var(--ease)}
.fc:hover{border-color:var(--text-3);transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.06)}
.fc-visual{height:100px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.fc-visual-name{font-family:var(--display);font-size:1.3rem;font-weight:700;color:#fff;letter-spacing:-.02em;position:relative;z-index:1}
.fc-body{padding:12px 14px 14px}
.fc-source{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;text-transform:uppercase;color:var(--text-3);margin-bottom:5px}
.fc-title{font-family:var(--body);font-size:.82rem;font-weight:500;line-height:1.4;color:var(--text-1);margin-bottom:6px}
.fc-meta{display:flex;align-items:center;gap:8px;margin-top:4px}
.fc-time{font-family:var(--mono);font-size:.48rem;color:var(--ink-faint);letter-spacing:.04em}
.fc-tag{font-family:var(--mono);font-size:.42rem;letter-spacing:.06em;text-transform:uppercase;padding:2px 6px;border-radius:2px;background:var(--surface);border:1px solid var(--border);color:var(--text-3)}

/* ═══ MAJOR EVENTS TIMELINE ═══ */
.timeline{
  background:var(--accent-light);
  border-top:1px solid rgba(90,138,134,.15);
  border-bottom:1px solid rgba(90,138,134,.15);
  padding:48px 0 56px;
  margin-top:8px;
}
.timeline-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px}
.timeline-label{
  font-family:var(--mono);font-size:1.1rem;letter-spacing:.10em;text-transform:uppercase;
  color:var(--text-1);display:flex;align-items:center;margin:0;font-weight:500;
}
.timeline-arrows{display:flex;gap:6px}
.timeline-arrow{
  width:34px;height:34px;border-radius:50%;border:1px solid rgba(90,138,134,.3);
  background:var(--bg);color:var(--accent);cursor:pointer;display:flex;align-items:center;
  justify-content:center;font-size:.9rem;transition:all var(--ease);flex-shrink:0;
}
.timeline-arrow:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
.timeline-arrow.hide{opacity:.25;pointer-events:none}
.timeline-viewport{
  overflow-x:auto;scrollbar-width:none;scroll-behavior:smooth;
}
.timeline-viewport::-webkit-scrollbar{display:none}
.timeline-track{
  display:grid;position:relative;grid-auto-flow:column;
}
.timeline-spine{
  position:absolute;top:9px;left:9px;height:1px;background:rgba(90,138,134,.3);
}
.timeline-event{position:relative;padding-right:24px;cursor:pointer;transition:opacity var(--ease);box-sizing:border-box}
.timeline-event:last-child{padding-right:0}
.timeline-event:hover{opacity:.7}
.timeline-node{
  width:18px;height:18px;border-radius:50%;background:var(--bg);
  border:2px solid var(--accent);position:relative;z-index:1;margin-bottom:18px;flex-shrink:0;
}
.timeline-event:last-child .timeline-node{
  background:var(--accent);border-color:var(--accent);
  animation:tl-pulse 2s ease-in-out infinite;
}
@keyframes tl-pulse{0%,100%{box-shadow:0 0 0 0 rgba(90,138,134,.35)}50%{box-shadow:0 0 0 8px rgba(90,138,134,0)}}
.timeline-date{font-family:var(--mono);font-size:.65rem;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);margin-bottom:8px;font-weight:500}
.timeline-headline{
  font-family:var(--body);font-size:.95rem;font-weight:500;line-height:1.45;
  color:var(--text-1);letter-spacing:-.01em;
  display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden;
}

.load-more{text-align:center;padding:32px 0}
.load-more button{font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;padding:12px 36px;border:1px solid var(--border);background:var(--surface);color:var(--text-2);border-radius:3px;cursor:pointer;transition:all var(--ease)}
.load-more button:hover{background:var(--text-1);color:var(--bg);border-color:var(--text-1)}

/* ═══ SIDEBAR ═══ */
.sidebar{padding-left:36px;padding-top:20px}
.sidebar-sec{margin-bottom:32px}
.sidebar-sec h4{font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;text-transform:uppercase;color:var(--text-3);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.chart-widgets{display:flex;flex-direction:column;gap:12px}
.chart-widget{border:1px solid var(--border);border-radius:4px;padding:14px 16px 10px;transition:border-color var(--ease)}
.chart-widget:hover{border-color:var(--text-3)}
.cw-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2px}
.cw-name{font-family:var(--sans);font-size:.78rem;font-weight:600;color:var(--text-1)}
.cw-period{font-family:var(--mono);font-size:.42rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-faint);padding:2px 6px;border:1px solid var(--border);border-radius:2px}
.cw-row{display:flex;align-items:baseline;gap:8px;margin-bottom:8px}
.cw-val{font-family:var(--mono);font-size:1rem;font-weight:500;color:var(--text-1);letter-spacing:-.02em}
.cw-chg{font-family:var(--mono);font-size:.65rem;font-weight:500}
.cw-chg.up{color:var(--green)}
.cw-chg.down{color:var(--red)}
.cw-chart{display:flex;gap:8px;align-items:stretch}
.cw-spark{flex:1;height:56px;min-width:0}
.cw-spark svg{width:100%;height:100%}
.cw-spark path{fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.cw-spark .spark-fill{stroke:none;opacity:.08}
.cw-spark .grid-line{stroke:var(--border);stroke-width:0.5;stroke-dasharray:3,3;fill:none}
.cw-y{display:flex;flex-direction:column;justify-content:space-between;padding:1px 0;flex-shrink:0}
.cw-y span{font-family:var(--mono);font-size:.42rem;color:var(--ink-faint);letter-spacing:.02em;line-height:1;text-align:right}
.cw-x{display:flex;justify-content:space-between;margin-top:5px}
.cw-x span{font-family:var(--mono);font-size:.42rem;color:var(--ink-faint);letter-spacing:.02em}

.trending{list-style:none}
.trending li{display:flex;align-items:baseline;gap:10px;padding:8px 0;border-bottom:1px solid var(--border-light);font-size:.8rem;color:var(--text-2);cursor:pointer;transition:color var(--ease)}
.trending li:hover{color:var(--text-1)}
.trending li:last-child{border-bottom:none}
.tn{font-family:var(--mono);font-size:.6rem;color:var(--ink-faint);font-weight:500;min-width:16px}

/* Daily Briefing Widget */
.db-widget{background:var(--surface-dark);border:none;border-radius:4px;padding:18px}
.db-widget ul{list-style:none}
.db-widget li{font-size:.78rem;color:rgba(255,255,255,.75);line-height:1.55;padding:6px 0 6px 14px;border-bottom:1px solid rgba(255,255,255,.08);position:relative}
.db-widget li:last-child{border-bottom:none}
.db-widget li::before{content:'';position:absolute;left:0;top:12px;width:4px;height:4px;border-radius:50%;background:var(--accent)}

/* Subscribe Widget */
.sub-widget{background:var(--accent-light);border:1px solid rgba(90,138,134,.15);border-radius:4px;padding:18px}
.sub-widget h4{font-family:var(--serif);font-size:1.05rem;font-weight:400;margin-bottom:4px}
.sub-widget p{font-size:.75rem;color:var(--text-2);margin-bottom:12px}
.sub-widget input{width:100%;font-family:var(--sans);font-size:.75rem;padding:8px 12px;border:1px solid var(--border);border-radius:3px;outline:none;margin-bottom:6px;transition:border-color var(--ease)}
.sub-widget input:focus{border-color:var(--accent)}
.sub-widget button{width:100%;font-family:var(--sans);font-size:.75rem;font-weight:500;padding:8px;background:var(--accent);color:#fff;border:none;border-radius:3px;cursor:pointer;transition:background var(--ease)}
.sub-widget button:hover{background:var(--accent-hover)}

/* ═══ CTA BREAK ═══ */
.cta-break{
  background:var(--surface-dark);padding:52px 48px;border-radius:6px;margin:48px 0;
  display:flex;align-items:center;gap:48px;
}
.cta-txt{flex:1}
.cta-txt h3{font-family:var(--display);font-size:1.5rem;font-weight:700;color:#fff;line-height:1.25;margin-bottom:8px}
.cta-txt h3 em{font-style:italic;font-weight:400;color:var(--accent)}
.cta-txt p{font-size:.84rem;color:rgba(255,255,255,.55);line-height:1.6;max-width:440px}
.cta-txt .tagline{font-family:var(--mono);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-top:12px}
.cta-form{flex-shrink:0}
.cta-form .row{display:flex;gap:6px}
.cta-form input{font-family:var(--sans);font-size:.78rem;padding:11px 14px;width:240px;border:1px solid rgba(255,255,255,.15);border-radius:3px;background:rgba(255,255,255,.06);color:#fff;outline:none;transition:border-color var(--ease)}
.cta-form input:focus{border-color:rgba(255,255,255,.35)}
.cta-form input::placeholder{color:rgba(255,255,255,.3)}
.cta-form button{font-family:var(--sans);font-size:.78rem;font-weight:500;padding:11px 22px;background:var(--accent);color:#fff;border:none;border-radius:3px;cursor:pointer;transition:opacity var(--ease)}
.cta-form button:hover{opacity:.85}
.cta-badges{display:flex;gap:16px;margin-top:8px}
.cta-badge{font-family:var(--mono);font-size:.45rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);display:flex;align-items:center;gap:5px}
.cta-badge::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--accent);flex-shrink:0}

/* ═══ SUBSCRIPTION POPUP ═══ */
.news-popup{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center}
.news-popup__overlay{position:absolute;inset:0;background:rgba(15,23,42,.55);backdrop-filter:blur(8px);animation:fadeIn 0.2s ease}
.news-popup__content{position:relative;background:linear-gradient(145deg,var(--surface) 0%,var(--surface-warm) 100%);border:1px solid var(--border);border-radius:16px;padding:32px 36px;min-width:380px;max-width:90vw;box-shadow:0 25px 80px rgba(0,0,0,.25),0 10px 30px rgba(0,0,0,.15);animation:slideUp 0.3s cubic-bezier(0.16,1,0.3,1)}
.news-popup__close{position:absolute;top:16px;right:20px;background:none;border:none;font-size:1.75rem;color:var(--text-3);cursor:pointer;padding:0;line-height:1;transition:all 0.2s ease;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:50%}
.news-popup__close:hover{color:var(--text-1);background:var(--surface-warm);transform:rotate(90deg)}
.news-popup__title{font-family:var(--serif);font-size:1.35rem;font-weight:400;margin-bottom:8px;color:var(--text-1);letter-spacing:-0.02em}
.news-popup__subtitle{font-size:0.85rem;color:var(--text-3);margin-bottom:24px}
.sub-popup__form{display:flex;flex-direction:column;gap:16px;margin-top:20px}
.sub-popup__field{display:flex;flex-direction:column;gap:6px}
.sub-popup__field label{font-family:var(--sans);font-size:0.75rem;font-weight:500;color:var(--text-2);text-transform:uppercase;letter-spacing:0.04em}
.sub-popup__optional{color:var(--text-3);font-weight:400;text-transform:none}
.sub-popup__field input{font-family:var(--sans);font-size:0.9rem;padding:12px 14px;background:var(--surface);border:1.5px solid var(--border);border-radius:8px;color:var(--text-1);outline:none;transition:all 0.2s ease}
.sub-popup__field input:focus{border-color:var(--accent);background:var(--surface-warm)}
.sub-popup__field input::placeholder{color:var(--text-3);opacity:0.6}
.sub-popup__submit{font-family:var(--sans);font-size:0.85rem;font-weight:600;padding:14px 24px;background:var(--accent);color:var(--surface-dark);border:none;border-radius:8px;cursor:pointer;transition:all 0.2s ease;margin-top:8px}
.sub-popup__submit:hover{opacity:0.9;transform:translateY(-1px)}
.sub-popup__submit:disabled{opacity:0.6;cursor:not-allowed;transform:none}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* ═══ RESPONSIVE ═══ */
@media(max-width:1024px){
  .news-grid{grid-template-columns:1fr}
  .feed{border-right:none;padding-right:0}
  .sidebar{padding-left:0;padding-top:32px;border-top:1px solid var(--border)}
  .clocks{display:none}
  .cta-break{flex-direction:column;text-align:left;padding:32px 28px}
  .timeline-headline{font-size:.75rem}
  .timeline-event{padding-right:14px}
}
@media(max-width:640px){
  .wrap{padding:0 20px}
  .nav{display:none}
  .filter-bar{flex-direction:column;align-items:stretch}
  .search-wrap{max-width:100%}
  .tabs{overflow-x:auto;flex-wrap:nowrap;-webkit-overflow-scrolling:touch}
  .fc{flex:0 0 200px}
  .timeline-arrow{width:26px;height:26px;font-size:.7rem}
  .fc-visual{height:80px}
  .fc-visual-name{font-size:1.05rem}
  .ni-body h3{font-size:.88rem}
  .cta-form .row{flex-direction:column}
  .cta-form input{width:100%}
  .breaking-text{font-size:.75rem}
}
