// ═══ City Clocks ═══
function clocks(){
  const o={hour:'2-digit',minute:'2-digit',hour12:false};
  const z=[['ck-fra','Europe/Berlin','de-DE'],['ck-lon','Europe/London','en-GB'],['ck-zur','Europe/Zurich','de-CH'],['ck-nyc','America/New_York','en-US'],['ck-sin','Asia/Singapore','en-SG']];
  z.forEach(([id,tz,loc])=>{const el=document.getElementById(id);if(el)el.textContent=new Date().toLocaleTimeString(loc,{...o,timeZone:tz})});
}
clocks();setInterval(clocks,30000);

// ═══ Dateline ═══
(function(){
  const el=document.getElementById('dateline');
  if(el){
    const d=new Date();
    const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
    el.textContent=days[d.getDay()]+', '+months[d.getMonth()]+' '+d.getDate()+', '+d.getFullYear();
  }
})();

// ═══ Scroll Reveal ═══
const observer=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
</script>

<script>
  // ═══ News Publisher Popup Handler ═══
  document.addEventListener('DOMContentLoaded', function() {
    console.log('[News Popup] Initializing...');
    const popup = document.getElementById('newsPopup');
    const popupList = document.getElementById('newsPopupList');
    if (!popup || !popupList) {
      console.log('[News Popup] Missing popup elements');
      return;
    }
    console.log('[News Popup] Found popup elements');

    const popupClose = popup.querySelector('.news-popup__close');
    const popupOverlay = popup.querySelector('.news-popup__overlay');

    function openPopup(sources, urls) {
      while (popupList.firstChild) {
        popupList.removeChild(popupList.firstChild);
      }
      sources.forEach((source, index) => {
        const url = urls[index];
        if (!url) return;

        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = url;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';

        const publisherSpan = document.createElement('span');
        publisherSpan.className = 'news-popup__publisher';
        publisherSpan.textContent = source;

        const arrowSpan = document.createElement('span');
        arrowSpan.className = 'news-popup__arrow';
        arrowSpan.textContent = '→';

        a.appendChild(publisherSpan);
        a.appendChild(arrowSpan);
        li.appendChild(a);
        popupList.appendChild(li);
      });
      popup.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      popup.style.display = 'none';
      document.body.style.overflow = '';
    }

    popupClose?.addEventListener('click', closePopup);
    popupOverlay?.addEventListener('click', closePopup);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePopup(); });

    // Handle news item clicks
    const newsContainers = document.querySelectorAll('.feed, .featured-scroll');
    console.log('[News Popup] Found containers:', newsContainers.length);
    if (newsContainers.length === 0) {
      console.log('[News Popup] No containers found');
      return;
    }

    newsContainers.forEach((container, i) => {
      console.log('[News Popup] Container', i, 'class:', container.className);
      container.addEventListener('click', (e) => {
        console.log('[News Popup] Click detected');
        const item = e.target.closest('.news-item');
        if (!item) {
          console.log('[News Popup] No .news-item found');
          return;
        }
        console.log('[News Popup] Found news-item');

        e.preventDefault();

        const sourcesStr = item.getAttribute('data-sources');
        const urlsStr = item.getAttribute('data-urls');
        console.log('[News Popup] sources:', sourcesStr?.substring(0, 50));
        console.log('[News Popup] urls:', urlsStr?.substring(0, 50));
        if (!sourcesStr || !urlsStr) return;

        let sources, urls;
        try {
          sources = JSON.parse(sourcesStr);
          urls = JSON.parse(urlsStr);
        } catch (err) {
          console.log('[News Popup] Failed to parse data:', err);
          return;
        }

        console.log('[News Popup] Parsed:', sources.length, 'sources,', urls.length, 'urls');

        if (!Array.isArray(urls) || urls.length === 0) {
          console.log('[News Popup] No URLs to open');
          return;
        }

        if (urls.length === 1) {
          console.log('[News Popup] Opening single URL:', urls[0]);
          window.open(urls[0], '_blank', 'noopener,noreferrer');
        } else {
          // Fallback: if no sources, use domains from URLs
          const displaySources = sources?.length ? sources : urls.map((url) => {
            try {
              const hostname = new URL(url).hostname.replace('www.', '');
              const parts = hostname.split('.');
              return parts[parts.length - 2]?.charAt(0).toUpperCase() + parts[parts.length - 2]?.slice(1) || hostname;
            } catch {
              return 'News';
            }
          });
          console.log('[News Popup] Opening popup with', displaySources.length, 'sources');
          openPopup(displaySources, urls);
        }
      });
    });
  });
</script>

<script>
  // ═══ Search Functionality ═══
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.querySelector('.search-wrap input[type="text"]');
    const newsItems = document.querySelectorAll('.feed .news-item');
    const featuredItems = document.querySelectorAll('.featured-scroll .news-item');

    if (!searchInput) return;

    const feedGroup = document.querySelector('.feed .feed-group');
    let noResultsMsg = feedGroup?.querySelector('.no-results-message');
    if (!noResultsMsg && feedGroup) {
      noResultsMsg = document.createElement('div');
      noResultsMsg.className = 'no-results-message hidden';
      noResultsMsg.textContent = 'No news found matching your search.';
      feedGroup.appendChild(noResultsMsg);
    }

    searchInput.addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase().trim();
      let visibleCount = 0;

      // Filter main news feed
      newsItems.forEach(item => {
        const title = item.querySelector('h3')?.textContent?.toLowerCase() || '';
        const bpoints = item.querySelector('p')?.textContent?.toLowerCase() || '';
        const source = item.querySelector('.ni-src')?.textContent?.toLowerCase() || '';
        const theme = item.getAttribute('data-cat')?.toLowerCase() || '';

        const matches = title.includes(query) ||
                       bpoints.includes(query) ||
                       source.includes(query) ||
                       theme.includes(query);

        item.style.display = matches ? '' : 'none';
        if (matches) visibleCount++;
      });

      // Filter featured news
      featuredItems.forEach(item => {
        const title = item.querySelector('.fc-title')?.textContent?.toLowerCase() || '';
        const source = item.querySelector('.fc-source')?.textContent?.toLowerCase() || '';

        const matches = title.includes(query) || source.includes(query);
        item.style.display = matches ? '' : 'none';
      });

      // Show/hide no results message
      if (noResultsMsg) {
        noResultsMsg.classList.toggle('hidden', visibleCount > 0 || !query);
      }
    });
  });
</script>

<script>
  import { initSubscriptionPopup } from '../scripts/subscription';
  initSubscriptionPopup({
    triggerSelector: '[data-use-popup]'
  });
</script>

</Layout>
