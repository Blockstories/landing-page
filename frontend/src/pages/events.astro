<script>
// ═══ Events Filter + Preview ═══
(function(){
  const cards=document.querySelectorAll('.ev-card');
  const filters=document.getElementById('evFilters');
  const btn=document.getElementById('viewMoreBtn');
  const wrap=document.getElementById('viewMoreWrap');
  if(!cards.length||!filters)return;

  const MAX_VISIBLE=5;
  let activeFilter='all';
  let expanded=false;

  function applyView(){
    let visibleCount=0;
    cards.forEach(c=>{
      const type=c.dataset.type||'';
      const matchesFilter=activeFilter==='all'||type===activeFilter;
      c.classList.toggle('ev-filtered',!matchesFilter);
      if(matchesFilter){
        visibleCount++;
        c.classList.toggle('ev-hidden',!expanded&&visibleCount>MAX_VISIBLE);
      }else{
        c.classList.remove('ev-hidden');
      }
    });
    const totalVisible=Array.from(cards).filter(c=>!c.classList.contains('ev-filtered')).length;
    if(wrap){
      wrap.style.display=(!expanded&&totalVisible>MAX_VISIBLE)?'':'none';
    }
  }

  filters.querySelectorAll('.ev-filter').forEach(f=>{
    f.addEventListener('click',()=>{
      filters.querySelectorAll('.ev-filter').forEach(b=>b.classList.remove('on'));
      f.classList.add('on');
      activeFilter=f.dataset.filter;
      expanded=false;
      applyView();
    });
  });

  if(btn){
    btn.addEventListener('click',()=>{
      expanded=true;
      applyView();
    });
  }

  applyView();
})();

// ═══ Sponsor Form ═══
(function(){
  const form=document.getElementById('sponsorForm');
  if(!form)return;
  form.addEventListener('submit',function(e){
    e.preventDefault();
    const btn=form.querySelector('.sf-submit');
    const orig=btn.textContent;
    btn.textContent='Inquiry Sent!';
    btn.style.background='var(--green)';
    setTimeout(()=>{btn.textContent=orig;btn.style.background=''},3000);
  });
})();

// ═══ Scroll Reveal ═══
const observer=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
</script>
