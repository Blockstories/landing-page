---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Event } from '../../../backend/db/types.js';
import { getNewestEvents } from '../../../backend/db/queries.js';

// Fetch events directly from DB during SSR
let events: Event[] = [];

try {
  console.log(`[events.astro] Fetching events from DB`);
  events = await getNewestEvents(20);
  console.log(`[events.astro] Loaded ${events.length} events`);
} catch (error) {
  console.error("[events.astro] Failed to fetch events from DB:", error);
}

// Helper to format date from timestamp
function formatEventDate(dateTimestamp: number) {
  const date = new Date(dateTimestamp * 1000);
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return {
    day: date.getDate().toString().padStart(2, '0'),
    month: months[date.getMonth()],
    monthKey: date.getMonth() + 1 // 1-12 for data-month
  };
}

// Helper to get event type from tags
function getEventType(tags: string[]): string {
  const typeTags = ['summit', 'dinner', 'webinar', 'workshop'];
  for (const tag of tags) {
    const lowerTag = tag.toLowerCase();
    if (typeTags.includes(lowerTag)) return lowerTag;
  }
  return 'summit'; // default
}

// Helper to get event series from tags
function getEventSeries(tags: string[]): { name: string; class: string } {
  const seriesTags = ['winter', 'summer', 'fall'];
  for (const tag of tags) {
    const lowerTag = tag.toLowerCase();
    if (seriesTags.includes(lowerTag)) {
      return {
        name: lowerTag.charAt(0).toUpperCase() + lowerTag.slice(1) + ' Series',
        class: lowerTag
      };
    }
  }
  return { name: 'Winter Series', class: 'winter' }; // default
}

// Helper to format timeframe string
function formatTimeframe(timeframeString?: string): string {
  if (!timeframeString) return '';
  return timeframeString;
}
