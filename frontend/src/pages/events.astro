    <div class="view-more-wrap reveal" id="viewMoreWrap">
      <button class="view-more-btn" id="viewMoreBtn">View More Events</button>
    </div>
  </div><!-- end upcoming wrap -->

  <!-- ═══ HORIZON SERIES SHOWCASE ═══ -->
