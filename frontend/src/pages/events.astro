            <div class="ev-body">
              <div class="ev-badges">
                <span class="ev-type">{eventType.charAt(0).toUpperCase() + eventType.slice(1)}</span>
                <span class={`ev-series ${eventSeries.class}`}>{eventSeries.name}</span>
              </div>
              <h3>{event.title}</h3>
              <div class="ev-meta">
                <span><span class="ev-meta-dot"></span>{event.location || 'Location TBA'}</span>
                {event.timeframeString && <span>{event.timeframeString}</span>}
              </div>
            </div>
            <div class="ev-action">
              {event.webUrl ? (
                <a href={event.webUrl} class="ev-btn" target="_blank" rel="noopener">Register</a>
              ) : (
                <button class="ev-btn">Register</button>
              )}
            </div>
          </div>
        );
      })}
      {events.length === 0 && (
        <div class="ev-card bs">
          <div class="ev-body">
            <h3>No upcoming events</h3>
            <p class="ev-desc">Check back soon for our next events.</p>
