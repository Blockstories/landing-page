      <button class="ev-filter" data-filter="dinner">Dinners</button>
      <button class="ev-filter" data-filter="webinar">Webinars</button>
      <button class="ev-filter" data-filter="workshop">Workshops</button>
    </div>

    <div class="events-list" id="eventsList">
      {events.map((event, index) => {
        const date = formatEventDate(event.date);
        const eventType = getEventType(event.tags);
        const eventSeries = getEventSeries(event.tags);
        return (
          <div class="ev-card bs" data-month={date.month.toLowerCase()} data-type={eventType}>
            <div class="ev-date">
              <div class="ev-day">{date.day}</div>
              <div class="ev-month">{date.month}</div>
            </div>
            <div class="ev-thumb">
              {event.thumbnailUrl ? (
                <img src={event.thumbnailUrl} alt={event.title} loading="lazy" />
              ) : (
                <svg viewBox="0 0 24 24"><path d="M21 19V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2zM8.5 13.5l2.5 3 3.5-4.5 4.5 6H5l3.5-5.5z"/></svg>
              )}
