.hero-video-bg video{width:100%;height:100%;object-fit:cover;object-position:center 20%;opacity:.12}
.events-hero::before{content:'';position:absolute;inset:0;z-index:0;background:linear-gradient(180deg,rgba(18,43,66,.5) 0%,rgba(18,43,66,.3) 40%,rgba(18,43,66,.7) 100%);pointer-events:none}
.events-hero::after{content:'';position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse at 70% 30%,rgba(90,138,134,.15) 0%,transparent 60%);pointer-events:none}
.hero-inner{position:relative;z-index:1;display:flex;flex-direction:column;gap:20px}
.hero-top{display:flex;justify-content:space-between;align-items:flex-start}
.hero-content{max-width:680px}
.hero-stats-inline{display:flex;gap:12px;flex-wrap:wrap;border-top:1px solid rgba(255,255,255,.1);padding-top:20px;margin-top:4px}
.hero-stat-pill{font-family:var(--mono);font-size:.55rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.5);padding:6px 16px;border:1px solid rgba(255,255,255,.12);border-radius:3px;background:rgba(255,255,255,.04)}
.hero-label{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.hero-label::before{content:'';width:24px;height:1px;background:var(--accent)}
.events-hero h1{font-family:var(--display);font-size:2.8rem;font-weight:700;color:#fff;line-height:1.15;letter-spacing:-.02em;margin-bottom:36px}
.events-hero h1 em{font-style:italic;font-weight:400;color:var(--accent)}
.hero-sub{font-family:var(--body);font-size:1.05rem;color:rgba(255,255,255,.55);line-height:1.65;max-width:560px;margin-bottom:28px}
.hero-ctas{display:flex;gap:16px;align-items:center;margin-bottom:24px}
.btn-outline{display:inline-block;font-family:var(--sans);font-size:.85rem;font-weight:500;padding:14px 32px;background:rgba(255,255,245,.92);color:var(--text-1);border:none;border-radius:3px;cursor:pointer;transition:all var(--ease)}
.btn-outline:hover{background:#fff}
.btn-accent{display:inline-block;font-family:var(--sans);font-size:.85rem;font-weight:500;padding:14px 32px;background:none;color:rgba(255,255,255,.8);border:1px solid rgba(255,255,255,.3);border-radius:3px;cursor:pointer;transition:all var(--ease)}
.btn-accent:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.5);color:#fff}
.hero-formats{display:flex;gap:8px;align-items:center}
.hero-format-badge{font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.35);padding:4px 10px;border:1px solid rgba(255,255,255,.1);border-radius:2px}

/* ═══ SECTION HEADERS ═══ */
.section-hdr{padding:72px 0 28px;display:flex;align-items:baseline;justify-content:space-between;gap:24px}
.section-hdr h2{font-family:var(--display);font-size:1.6rem;font-weight:700;letter-spacing:-.01em;flex-shrink:0}
.section-hdr-line{flex:1;height:1px;background:var(--border)}
.invite-note{font-family:var(--mono);font-size:.6rem;letter-spacing:.06em;color:var(--text-3);margin-bottom:28px}

/* ═══ MONTH TABS ═══ */
.ev-filters{display:flex;gap:6px;margin-bottom:36px;flex-wrap:wrap}
.ev-filter{font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:9px 22px;border-radius:3px;cursor:pointer;color:var(--text-3);background:none;border:1px solid transparent;transition:all var(--ease)}
.ev-filter:hover{color:var(--text-2);border-color:var(--border)}
.ev-filter.on{background:var(--text-1);color:var(--bg);border-color:var(--text-1)}
.ev-card.ev-filtered{display:none}
.ev-card.ev-hidden{display:none}
.view-more-wrap{text-align:center;margin-top:var(--sp-xl)}
.view-more-btn{display:inline-block;padding:12px 36px;border:1px solid var(--border);border-radius:6px;background:var(--bg);font-family:var(--sans);font-size:.85rem;font-weight:500;color:var(--text-2);cursor:pointer;transition:all var(--ease)}
.view-more-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-light)}

/* ═══ EVENT CARDS ═══ */
.events-list{display:flex;flex-direction:column;gap:0}
.ev-card{display:grid;grid-template-columns:80px 96px 1fr auto;gap:20px;padding:28px 0;border-bottom:1px solid var(--border-light);transition:background var(--ease)}
.ev-thumb{width:96px;height:96px;border-radius:6px;background:var(--surface-warm);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
.ev-thumb img{width:100%;height:100%;object-fit:cover}
.ev-thumb svg{width:28px;height:28px;fill:var(--ink-faint);opacity:.45}
.ev-card:nth-child(odd){background:var(--surface)}
.ev-card:nth-child(even){background:var(--bg)}
.ev-card:hover{opacity:.92}
.ev-card:first-child{border-top:1px solid var(--border)}
.ev-card.bs{border-left:3px solid var(--accent);padding-left:17px;margin-left:-20px;padding-right:0}
.ev-card.bs:nth-child(odd){background:var(--surface)}
.ev-card.bs:nth-child(even){background:var(--bg)}
.ev-date{text-align:center;padding-top:2px}
.ev-day{font-family:var(--display);font-size:2rem;font-weight:700;line-height:1;color:var(--text-1)}
.ev-month{font-family:var(--mono);font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);margin-top:2px}
.ev-card.bs .ev-day{color:var(--accent)}
.ev-body h3{font-family:var(--body);font-size:1rem;font-weight:500;line-height:1.4;margin-bottom:6px}
.ev-badges{display:flex;gap:6px;margin-bottom:6px;flex-wrap:wrap}
.ev-type{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;border-radius:2px;background:var(--surface);border:1px solid var(--border);color:var(--text-3)}
.ev-card.bs .ev-type{background:rgba(90,138,134,.1);border-color:rgba(90,138,134,.2);color:var(--accent)}
.ev-series{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;border-radius:2px}
.ev-series.winter{background:rgba(138,109,90,.1);color:#8A6D5A;border:1px solid rgba(138,109,90,.2)}
.ev-series.summer{background:rgba(90,138,134,.1);color:var(--accent);border:1px solid rgba(90,138,134,.2)}
.ev-series.fall{background:rgba(30,75,122,.1);color:#1E4B7A;border:1px solid rgba(30,75,122,.2)}
.ev-meta{font-size:.78rem;color:var(--text-3);margin-bottom:6px;display:flex;gap:16px;align-items:center}
.ev-meta-dot{display:inline-block;width:4px;height:4px;border-radius:50%;background:var(--text-3);margin-right:6px;vertical-align:middle}
.ev-desc{font-size:.82rem;color:var(--text-2);line-height:1.55}
.ev-action{display:flex;align-items:flex-start;padding-top:4px;flex-shrink:0;padding-right:12px}
.ev-btn{font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:8px 20px;border:1px solid var(--border);background:var(--surface);color:var(--text-2);border-radius:3px;cursor:pointer;transition:all var(--ease);white-space:nowrap}
.ev-btn:hover{background:var(--text-1);color:var(--bg);border-color:var(--text-1)}
.ev-card.bs .ev-btn{border-color:var(--accent);color:var(--accent)}
.ev-card.bs .ev-btn:hover{background:var(--accent);color:#fff}

/* ═══ HORIZON SERIES SHOWCASE ═══ */
.horizon{background:var(--surface);padding:80px 0;margin-top:64px;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.horizon-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px}
.horizon-text h2{font-family:var(--display);font-size:1.8rem;font-weight:700;line-height:1.2;margin-bottom:8px;letter-spacing:-.01em}
.horizon-text h2 em{font-style:italic;font-weight:400;color:var(--accent)}
.horizon-label{font-family:var(--mono);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.horizon-label::before{content:'';width:20px;height:1px;background:var(--accent)}
.horizon-desc{font-family:var(--body);font-size:.92rem;color:var(--text-2);line-height:1.65;margin-bottom:28px}
.horizon-stats{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.h-stat{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:18px 16px;text-align:center}
.h-stat-val{font-family:var(--display);font-size:1.5rem;font-weight:700;color:var(--text-1);line-height:1}
.h-stat-lbl{font-family:var(--mono);font-size:.48rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);margin-top:4px}
.gallery-video{border-radius:4px;overflow:hidden;align-self:center}
.gallery-video video{display:block;width:100%;height:auto}
.gv-caption{padding:14px 16px;background:var(--surface-dark)}
.gv-caption-eye{font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:4px}
.gv-caption-title{font-family:var(--display);font-size:1rem;font-weight:600;color:#fff;line-height:1.3;letter-spacing:-.01em}
.gv-caption-title em{font-style:italic;font-weight:400;color:var(--accent)}

/* ═══ THEMES TICKER ═══ */
.themes-ticker{background:var(--surface-dark);padding:56px 0 44px;overflow:hidden}
.themes-ticker-header{text-align:center;margin-bottom:32px}
.themes-ticker-label{font-family:var(--mono);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;display:flex;align-items:center;gap:8px;justify-content:center}
.themes-ticker-label::before,.themes-ticker-label::after{content:'';width:20px;height:1px;background:var(--accent)}
.themes-ticker-title{font-family:var(--display);font-size:1.5rem;font-weight:700;color:#fff;letter-spacing:-.01em}
.themes-ticker-title em{font-style:italic;font-weight:400;color:var(--accent)}
.ticker-track{display:flex;width:max-content;animation:tickerScroll 28s linear infinite}
.ticker-track:hover{animation-play-state:paused}
.ticker-item{font-family:var(--display);font-size:1.1rem;font-weight:600;color:rgba(255,255,255,.45);white-space:nowrap;padding:0 20px;display:flex;align-items:center;gap:20px;transition:color .3s ease}
.ticker-item:hover{color:rgba(255,255,255,.9)}
.ticker-sep{width:4px;height:4px;border-radius:50%;background:var(--accent);opacity:.5;flex-shrink:0}
@keyframes tickerScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ═══ TESTIMONIALS ═══ */
.testimonials{padding:72px 0;border-bottom:1px solid var(--border)}
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
.test-card{background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:24px;text-align:center;display:flex;flex-direction:column;align-items:center}
.test-quote{font-family:var(--body);font-size:.88rem;color:var(--text-2);line-height:1.6;font-style:italic;margin-bottom:16px}
.test-quote::before{content:'\201C';font-family:var(--display);font-size:1.8rem;color:var(--accent);line-height:0;vertical-align:-.35em;margin-right:2px}
.test-avatar{width:56px;height:56px;border-radius:50%;background:var(--accent-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;margin:0 auto 12px}
.test-avatar svg{width:28px;height:28px;fill:var(--accent);opacity:.7}
.test-author{font-size:.75rem;font-weight:600;color:var(--text-1)}
.test-role{font-family:var(--mono);font-size:.5rem;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3);margin-top:2px}

/* ═══ OUR FORMATS ═══ */
.formats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:28px}
.format-card{border:1px solid var(--border);border-radius:6px;overflow:hidden;transition:all var(--ease)}
.format-card:hover{border-color:var(--text-3)}
.format-img{width:100%;aspect-ratio:16/9;background:var(--surface-warm);display:flex;align-items:center;justify-content:center;overflow:hidden}
.format-img img{width:100%;height:100%;object-fit:cover}
.format-img svg{width:36px;height:36px;fill:var(--ink-faint);opacity:.35}
.format-body{padding:24px}
.format-label{font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:8px}
.format-name{font-family:var(--display);font-size:1.2rem;font-weight:600;color:var(--text-1);margin-bottom:10px}
.format-desc{font-family:var(--body);font-size:.85rem;color:var(--text-2);line-height:1.65}

/* ═══ AFTERMOVIES ═══ */
.aftermovies{padding:48px 0 56px;border-bottom:1px solid var(--border)}
.aftermovies-scroll{display:flex;gap:24px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding-bottom:8px;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.aftermovies-scroll::-webkit-scrollbar{height:4px}
.aftermovies-scroll::-webkit-scrollbar-track{background:transparent}
.aftermovies-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.am-card{flex:0 0 320px;scroll-snap-align:start;border:1px solid var(--border);border-radius:6px;overflow:hidden;transition:all var(--ease);cursor:pointer}
.am-card:hover{border-color:var(--text-3)}
.am-thumb{position:relative;width:100%;aspect-ratio:16/9;background:var(--surface-dark);display:flex;align-items:center;justify-content:center;overflow:hidden}
.am-thumb img{width:100%;height:100%;object-fit:cover;opacity:.7;transition:opacity var(--ease)}
.am-card:hover .am-thumb img{opacity:.85}
.am-play{position:absolute;width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.92);display:flex;align-items:center;justify-content:center;transition:transform var(--ease),background var(--ease);z-index:1}
.am-play svg{width:20px;height:20px;fill:var(--surface-dark);margin-left:2px}
.am-card:hover .am-play{transform:scale(1.08);background:#fff}
.am-body{padding:16px 18px}
.am-series{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px}
.am-series.winter{color:#8A6D5A}
.am-series.summer{color:var(--accent)}
.am-series.fall{color:#1E4B7A}
.am-title{font-family:var(--display);font-size:1rem;font-weight:600;color:var(--text-1);margin-bottom:4px}
.am-meta{font-family:var(--mono);font-size:.5rem;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3)}

/* ═══ SPONSOR SHOWCASE ═══ */
.sponsors{padding:72px 0 80px;background:var(--surface);border-top:none;border-bottom:1px solid var(--border)}
.sponsor-headline{font-family:var(--display);font-size:1.5rem;font-weight:700;font-style:italic;color:var(--text-1);margin-bottom:48px;letter-spacing:-.01em;text-align:center}
.sponsor-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:32px 48px}
.sponsor-tile{display:flex;align-items:center;justify-content:center;min-height:48px;transition:opacity var(--ease)}
.sponsor-tile:hover{opacity:.7}
.sponsor-tile span{font-family:var(--sans);font-size:.92rem;font-weight:600;color:var(--text-3);letter-spacing:.01em;white-space:nowrap}

/* ═══ BECOME A SPONSOR ═══ */
.sponsor-cta{background:var(--surface-dark);padding:80px 0}
.sponsor-cta-inner{display:grid;grid-template-columns:1fr 420px;gap:56px;align-items:start}
.sponsor-cta-text h2{font-family:var(--display);font-size:1.8rem;font-weight:700;color:#fff;line-height:1.2;margin-bottom:8px}
.sponsor-cta-text h2 em{font-style:italic;font-weight:400;color:var(--accent)}
.sponsor-cta-label{font-family:var(--mono);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.sponsor-cta-label::before{content:'';width:20px;height:1px;background:var(--accent)}
.sponsor-cta-desc{font-family:var(--body);font-size:.88rem;color:rgba(255,255,255,.55);line-height:1.65;margin-bottom:28px}
.partner-benefits{margin-bottom:32px}
.partner-benefits-label{font-family:var(--mono);font-size:.55rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:14px}
.partner-benefits-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.pb-item{display:flex;align-items:center;gap:10px;padding:12px 16px;border:1px solid rgba(255,255,255,.08);border-radius:4px;background:rgba(255,255,255,.03)}
.pb-icon{width:16px;height:1px;background:var(--accent);flex-shrink:0;margin-top:2px}
.pb-text{font-size:.75rem;color:rgba(255,255,255,.55);line-height:1.5}
.sponsor-side-stats{display:flex;gap:24px;margin-top:28px}
.s-stat{text-align:center}
.s-stat-val{font-family:var(--display);font-size:1.3rem;font-weight:700;color:#fff;line-height:1}
.s-stat-lbl{font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:4px}

/* ═══ SPONSOR FORM ═══ */
.sponsor-form{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:4px;padding:28px}
.sponsor-form h3{font-family:var(--display);font-size:1.1rem;font-weight:600;color:#fff;margin-bottom:4px}
.sponsor-form-sub{font-size:.75rem;color:rgba(255,255,255,.4);margin-bottom:20px}
.sf-row{margin-bottom:12px}
.sf-row label{font-family:var(--mono);font-size:.5rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.4);display:block;margin-bottom:4px}
.sf-row input,.sf-row select,.sf-row textarea{width:100%;font-family:var(--sans);font-size:.78rem;padding:10px 14px;border:1px solid rgba(255,255,255,.12);border-radius:3px;background:rgba(255,255,255,.05);color:#fff;outline:none;transition:border-color var(--ease)}
.sf-row input:focus,.sf-row select:focus,.sf-row textarea:focus{border-color:rgba(255,255,255,.3)}
.sf-row input::placeholder,.sf-row textarea::placeholder{color:rgba(255,255,255,.25)}
.sf-row select{appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='rgba(255,255,255,0.3)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;padding-right:32px}
.sf-row select option{background:var(--surface-dark);color:#fff}
.sf-row textarea{resize:vertical;min-height:80px}
.sf-row-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.sf-submit{width:100%;font-family:var(--sans);font-size:.78rem;font-weight:500;padding:12px;background:var(--accent);color:#fff;border:none;border-radius:3px;cursor:pointer;transition:all var(--ease);margin-top:4px}
.sf-submit:hover{background:var(--accent-hover)}

/* ═══ CTA BREAK ═══ */
.cta-break{
  background:var(--surface-dark);padding:52px 48px;border-radius:6px;margin:64px 0;
  display:flex;align-items:center;gap:48px;
}
.cta-txt{flex:1}
.cta-txt h3{font-family:var(--display);font-size:1.5rem;font-weight:700;color:#fff;line-height:1.25;margin-bottom:8px}
.cta-txt h3 em{font-style:italic;font-weight:400;color:var(--accent)}
.cta-txt p{font-size:.84rem;color:rgba(255,255,255,.55);line-height:1.6;max-width:440px}
.cta-txt .tagline{font-family:var(--mono);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-top:12px}
.cta-form{flex-shrink:0}
.cta-form .row{display:flex;gap:6px}
.cta-form input{font-family:var(--sans);font-size:.78rem;padding:11px 14px;width:240px;border:1px solid rgba(255,255,255,.15);border-radius:3px;background:rgba(255,255,255,.06);color:#fff;outline:none;transition:border-color var(--ease)}
.cta-form input:focus{border-color:rgba(255,255,255,.35)}
.cta-form input::placeholder{color:rgba(255,255,255,.3)}
.cta-form button{font-family:var(--sans);font-size:.78rem;font-weight:500;padding:11px 22px;background:var(--accent);color:#fff;border:none;border-radius:3px;cursor:pointer;transition:opacity var(--ease)}
.cta-form button:hover{opacity:.85}
.cta-badges{display:flex;gap:16px;margin-top:8px}
.cta-badge{font-family:var(--mono);font-size:.45rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);display:flex;align-items:center;gap:5px}
.cta-badge::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--accent);flex-shrink:0}

/* ═══ ANIMATIONS ═══ */
.reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ═══ RESPONSIVE ═══ */
@media(max-width:1024px){
  .hero-top{flex-direction:column;gap:24px}
  .events-hero h1{font-size:2.1rem}
  .hero-stat-val{font-size:1.3rem}
  .horizon-inner{grid-template-columns:1fr}
  .test-grid{grid-template-columns:1fr}
  .formats-grid{grid-template-columns:1fr 1fr}
