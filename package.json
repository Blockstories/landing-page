{
  "name": "landing-page",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --root frontend",
    "build": "astro build --root frontend",
    "preview": "astro preview --root frontend",
    "astro": "astro --root frontend",
    "test-beehiiv": "cd backend && tsx services/processBeehiivPost.ts",
    "test-softr": "cd backend && tsx services/softrService.ts",
    "test-openai": "cd backend && tsx services/openaiService.ts",
    "test-webhook": "cd backend && tsx services/testWebhook.ts",
    "webhook-server": "cd backend && tsx api/webhooks/server.ts",
    "backfill-posts": "cd backend && vite-node scripts/backfillPosts.ts",
    "test-backend": "cd backend && vite-node ../test-frontend/server.ts",
    "test": "vitest run --root backend",
    "test:watch": "vitest --root backend"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@libsql/client": "^0.17.0",
    "@types/node": "^20.0.0",
    "astro": "^5.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vite-node": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@astrojs/vercel": "^8.2.11",
    "dotenv": "^17.3.1"
  }
}
